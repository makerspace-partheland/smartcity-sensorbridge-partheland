{
  "mqtt_config": {
    "broker_url": "wss://mqtt.makerspace-partheland.de:443/mqtt",
    "keepalive": 45,
    "reconnect_min_delay": 1,
    "reconnect_max_delay": 30,
    "initial_reconnect_delay": 3,
    "topics": [
      {
        "topic": "senseBox:home/+",
        "name": "senseBox:home",
        "type": "sensebox",
        "description": "Alle senseBox:home Sensordaten (inkl. median)"
      },
      {
        "topic": "sensoren/+",
        "name": "Spezialisierte Sensoren",
        "type": "specialized_sensors",
        "description": "Spezialisierte Sensoren (Temperatur, Wasserstand)"
      }
    ]
  },
  "parsing": {
    "sensebox": {
      "data_path": "fields",
      "median_detection": {
        "topic_pattern": "senseBox:home/median",
        "suffix": "_median"
      }
    },
    "specialized_sensors": {
      "data_path": "fields",
      "ignore_rssi_only": true,
      "rssi_only_threshold": 2
    }
  },
  "sensor_categories": {
